# Fichier exemple des secrets
# Copier son contenu dans un fichier "env.properties" à la racine du projet et le remplir avec vos valeurs

# Configuration niveau de logging
APP_LOGGING_LEVEL=INFO

# Configuration des ports des apps
PATIENT_SERVICE_PORT=8082

# Configuration database MySQL pour patient_service
MYSQL_DATABASE=patient_service
MYSQL_ROOT_PASSWORD=mysql
MYSQL_USER=patient_service
MYSQL_PASSWORD=mysql
DB_PATIENT_URL=jdbc:mysql://localhost:3307/patient_service

DDL_AUTO=validate
